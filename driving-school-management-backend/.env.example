# Local development .env — copy this file to .env and adjust values.
# In production, set these as actual environment variables on your server.

# Use SQLite for zero-config local development.
# For production, switch to PostgreSQL, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/driving_school
DATABASE_URL=sqlite:///./driving_school.db

# ----- Application -----
APP_NAME=Driving School Management API
DEBUG=True
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- JWT / Auth -----
# Generate with: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-only-change-me-in-production-9f8e7d6c5b4a39281706152433425168
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----- Admin login credentials -----
# These are NOT exposed to the frontend. The frontend only sends email/password
# entered by the user; the server checks them against these values.
ADMIN_EMAIL=admin@drivingschool.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# ----- File uploads -----
UPLOAD_DIR=uploads
PHOTO_DIR=uploads/photos
MAX_PHOTO_SIZE_BYTES=5242880
